# Copy this file to `.streamlit/secrets.toml` and fill in your real credentials.
# Never commit secrets.toml to GitHub — it's already in .gitignore.

[google_sheets]
# Get spreadsheet_id from the Google Sheet URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
spreadsheet_id = "YOUR_GOOGLE_SHEETS_ID"

# Paste the entire contents of your service account JSON key file here
# Paste your credentials JSON string (minified)
credentials_json = """
{
  "type": "service_account",
  "project_id": "...",
  "private_key_id": "...",
  "private_key": "...",
  "client_email": "...",
  "client_id": "...",
  "auth_uri": "...",
  "token_uri": "...",
  "auth_provider_x509_cert_url": "...",
  "client_x509_cert_url": "...",
  "universe_domain": "googleapis.com"
}
"""
